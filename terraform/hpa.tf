# HorizontalPodAutoscaler for the server
resource "kubernetes_horizontal_pod_autoscaler_v2" "server_hpa" {
  metadata {
    name      = "server-hpa"
    namespace = kubernetes_namespace.flopachat.metadata[0].name
  }

  spec {
    scale_target_ref {
      api_version = "apps/v1"
      kind        = "Deployment"
      name        = kubernetes_deployment.server.metadata[0].name
    }

    min_replicas = 1
    max_replicas = 5

    metric {
      type = "Resource"
      resource {
        name = "cpu"
        target {
          type                = "Utilization"
          average_utilization = 70
        }
      }
    }

    metric {
      type = "Resource"
      resource {
        name = "memory"
        target {
          type                = "Utilization"
          average_utilization = 80
        }
      }
    }
  }
}

# HorizontalPodAutoscaler for the frontend
resource "kubernetes_horizontal_pod_autoscaler_v2" "front_hpa" {
  metadata {
    name      = "front-hpa"
    namespace = kubernetes_namespace.flopachat.metadata[0].name
  }

  spec {
    scale_target_ref {
      api_version = "apps/v1"
      kind        = "Deployment"
      name        = kubernetes_deployment.front.metadata[0].name
    }

    min_replicas = 1
    max_replicas = 3

    metric {
      type = "Resource"
      resource {
        name = "cpu"
        target {
          type                = "Utilization"
          average_utilization = 70
        }
      }
    }
  }
}
